# Připojení k PostgreSQL. Odpovídá docker-compose.yml pro lokální vývoj.
DATABASE_URL="postgresql://archiguide:archiguide@localhost:5432/archiguide?schema=public"

# Auth.js (T003). AUTH_SECRET je povinný — vygenerujte např. `npx auth secret`
# nebo `openssl rand -base64 32`.
AUTH_SECRET="dev-secret-change-me-0123456789abcdef"
AUTH_URL="http://localhost:3000"

# Google OAuth (volitelné). Bez těchto klíčů se Google tlačítko nezobrazí a
# přihlášení jede jen přes e-mail + heslo.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Úložiště médií (T014). `filesystem` (výchozí, dev) ukládá do MEDIA_STORAGE_DIR
# mimo `public/` — přístup jde vždy přes chráněnou serve routu. `s3` použije
# S3-kompatibilní úložiště (adaptér se doplní při nasazení).
MEDIA_STORAGE_DRIVER="filesystem"
MEDIA_STORAGE_DIR=".storage/media"

# Úložiště příloh (T023). Stejný princip jako u médií: `filesystem` (výchozí, dev)
# ukládá do ATTACHMENT_STORAGE_DIR mimo `public/` — stažení jde vždy přes
# autorizovanou routu `GET /api/attachments/[id]`. `s3` pro produkci (adaptér se
# doplní při nasazení). ATTACHMENT_MAX_BYTES omezuje velikost jedné přílohy
# (výchozí 25 MB).
ATTACHMENT_STORAGE_DRIVER="filesystem"
ATTACHMENT_STORAGE_DIR=".storage/attachments"
ATTACHMENT_MAX_BYTES="26214400"
