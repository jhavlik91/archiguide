# Připojení k PostgreSQL. Odpovídá docker-compose.yml pro lokální vývoj.
DATABASE_URL="postgresql://archiguide:archiguide@localhost:5432/archiguide?schema=public"

# Auth.js (T003). AUTH_SECRET je povinný — vygenerujte např. `npx auth secret`
# nebo `openssl rand -base64 32`.
AUTH_SECRET="dev-secret-change-me-0123456789abcdef"
AUTH_URL="http://localhost:3000"

# Google OAuth (volitelné). Bez těchto klíčů se Google tlačítko nezobrazí a
# přihlášení jede jen přes e-mail + heslo.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
