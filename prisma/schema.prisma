// ===========================================================================
// ArchiGuide — Prisma schema
//
// Schema je členěno komentářovými sekcemi per doména. Každý task přidává své
// modely do vlastní sekce a vlastní (append-only) migraci; cizí modely se
// nemění. Vazba na cizí model se řeší FK ze svého modelu.
// Viz TECHNICKE-ZADANI.md §4.2.
// ===========================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Core — User (T002)
// ---------------------------------------------------------------------------

/// Životní cyklus účtu. `deleted` je terminální stav.
enum UserStatus {
  active
  deactivated
  deleted
}

/// Základní identita uživatele; na ni se navěšují všechny domény.
model User {
  id     String     @id @default(cuid())
  /// Přihlašovací e-mail. `citext` zajišťuje case-insensitive unikátnost.
  email  String     @unique @db.Citext
  status UserStatus @default(active)
  /// BCP-47, výchozí čeština.
  locale String     @default("cs")

  /// Kontaktní preference (kanály, viditelnost kontaktu). Detail dořeší domény.
  contactPreferences      Json @default("{}")
  /// Notifikační preference per kanál/typ. Detail dořeší T011/T065.
  notificationPreferences Json @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Back-relace vlastněné jinými doménami (nepřidávají sloupec do `users`).
  credential          Credential? // T003
  authAccounts        AuthAccount[] // T003
  passwordResetTokens PasswordResetToken[] // T003
  roles               UserRole[] // T004
  professionalProfile ProfessionalProfile? // T007
  orgMemberships      OrganizationMember[] // T009
  verifications       Verification[] // T011
  portfolioProjects   PortfolioProject[] // T012 (owner = uživatel)
  portfolioCoauthors  PortfolioCoauthor[] // T012 (uvedení jako spoluautor)
  mediaAssets         MediaAsset[] // T014 (owner = uživatel)
  guideSessions       GuideSession[] // T017 (guide session připojená k účtu)
  attachments         Attachment[] // T023 (owner = uživatel)
  briefs              Brief[] // T021 (owner = uživatel)
  conversations       ConversationParticipant[] // T030 (účast v konverzacích)
  sentMessages        Message[] // T030 (odeslané zprávy)
  notifications       Notification[] // T032 (přijaté in-app notifikace)

  @@map("users")
}

// ---------------------------------------------------------------------------
// Auth (T003)
//
// Přihlašovací údaje a OAuth vazby žijí v samostatných modelech s FK na User,
// aby T003 neměnilo cizí model User (viz TECHNICKE-ZADANI.md §4.2). Session je
// bezstavová (JWT), proto zde není model Session.
// ---------------------------------------------------------------------------

/// Heslo pro credentials provider. Odděleno od User (1:1), hash bcrypt.
model Credential {
  userId       String   @id
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("credentials")
}

/// Propojení externího OAuth účtu (Google) s uživatelem. Umožňuje přihlášení
/// přes providera i propojení s existujícím účtem podle e-mailu.
model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Identifikátor providera, např. "google".
  provider          String
  /// ID účtu u providera (`sub`).
  providerAccountId String
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

/// Jednorázový token pro reset hesla. V DB jen SHA-256 hash; plaintext se
/// posílá pouze e-mailem. Expirace 1 h, po použití je `usedAt` vyplněno.
model PasswordResetToken {
  tokenHash String    @id
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// ---------------------------------------------------------------------------
// Taxonomie profesí (T005)
//
// Číselník profesních kategorií a profesí (17 kategorií dle legacy-master-spec
// §5). Čtení veřejné; správu řeší admin (T035). Vazbu profil↔profese vlastní
// T007. Zdroj seed dat: src/features/taxonomy/data.ts.
// ---------------------------------------------------------------------------

/// Životní cyklus položky číselníku. `archived` položka zůstává na historických
/// datech, ale nenabízí se v nových číselnících.
enum TaxonomyStatus {
  active
  archived
}

/// Hlavní profesní kategorie (např. „Architecture & Design").
model ProfessionCategory {
  id       String @id @default(cuid())
  /// Stabilní strojově čitelný identifikátor pro URL a odkazy.
  slug     String @unique
  name     String
  /// Pořadí pro zobrazení stromu (dle pořadí ve specifikaci).
  position Int

  professions Profession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profession_categories")
}

/// Konkrétní profese. Vždy patří do právě jedné kategorie.
model Profession {
  id                String         @id @default(cuid())
  slug              String         @unique
  name              String
  /// Alternativní názvy pro vyhledávání (např. „topenář" ↔ „topení").
  synonyms          String[]
  /// Regulovaná profese (vyžaduje autorizaci/oprávnění).
  regulated         Boolean        @default(false)
  /// Nápovědy k požadovanému ověření (např. autorizace ČKA/ČKAIT).
  verificationHints String[]
  status            TaxonomyStatus @default(active)
  /// Pořadí v rámci kategorie.
  position          Int

  categoryId String
  category   ProfessionCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)

  specializations Specialization[]
  profileLinks    ProfileProfession[] // T007 (back-relace, nepřidává sloupec)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([status])
  @@map("professions")
}

/// Užší specializace v rámci profese. Data doplní domény (např. T007); model
/// zde definuje vazbu a strukturu číselníku.
model Specialization {
  id          String  @id @default(cuid())
  slug        String  @unique
  label       String
  description String?

  professionId String
  profession   Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([professionId])
  @@map("specializations")
}

// ---------------------------------------------------------------------------
// Role model (T004)
//
// Systémové role uživatele. Jeden účet může mít víc rolí současně (multi-role,
// viz zadani/05-permission-matrix.md). Role se nikdy necachují v JWT bez
// expirace — čtou se per-request přes lib/session.ts, aby se ztráta role
// projevila okamžitě. Firemní role (owner/editor/…) řeší T009 samostatně.
// ---------------------------------------------------------------------------

/// Globální systémová role. Doménová/firemní oprávnění stojí nad těmito rolemi.
enum Role {
  client
  professional
  moderator
  admin
}

/// Přiřazení role uživateli (M:N přes vlastní model). Role přiděluje admin,
/// kromě self-service `client`/`professional` při onboardingu (T004 § Validation).
model UserRole {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role
  /// Kdo roli přidělil (admin) — audit. `null` = self-service onboarding.
  grantedBy String?
  createdAt DateTime @default(now())

  @@unique([userId, role])
  @@index([userId])
  @@map("user_roles")
}

// ---------------------------------------------------------------------------
// Profesionální profil (T007)
//
// Profil profesionála (1:1 s User). Odbornost je M:N na `Profession` z taxonomie
// (T005) přes join `ProfileProfession` s příznakem hlavní profese. `draft` profil
// je viditelný jen vlastníkovi, `published` je veřejný (route až T008). Příjem
// poptávek je nezávislý flag, aktivovatelný jen s ≥1 profesí (viz service vrstva).
// Specializace/regiony/jazyky jsou volné číselníky (String[]); taxonomie
// `Specialization` je zatím bez dat, doplní ji pozdější obsahový task.
// ---------------------------------------------------------------------------

/// Stav profilu. `draft` (rozpracovaný, jen vlastník) → `published` (veřejný).
enum ProfileStatus {
  draft
  published
}

/// Dostupnost profesionála pro nové zakázky.
enum Availability {
  open // otevřený novým zakázkám
  limited // omezená kapacita
  unavailable // momentálně nepřijímá
}

/// Forma spolupráce (může jich být víc současně).
enum CollaborationForm {
  remote // na dálku
  onsite // osobně / na místě
  hybrid // kombinace
}

/// Cenový model spolupráce.
enum PricingModel {
  hourly // hodinová sazba
  fixed // pevná cena za rozsah
  per_project // cena za projekt
  on_request // na vyžádání / dohodou
}

/// Profil profesionála. 1:1 s User; drží prezentaci, odbornost, dostupnost a
/// ceny. Většina polí je volitelná — vzniká postupně přes onboarding wizard.
model ProfessionalProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Základní informace (legacy-master-spec §22.1)
  /// Titulek profilu, max 120 znaků (validováno v appce).
  headline     String?
  /// Odkaz na profilovou fotku. Vlastní upload řeší T014; zde jen URL.
  photoUrl     String?
  bio          String?
  /// Lokalita (město/obec) profesionála.
  location     String?
  /// Regiony působnosti (volný číselník).
  serviceAreas String[]
  /// Jazyky, kterými profesionál komunikuje.
  languages    String[]

  // Odbornost (legacy-master-spec §22.2)
  yearsOfExperience Int?
  /// Užší specializace (volný text; taxonomie Specialization zatím bez dat).
  specializations   String[]
  /// Typy projektů, na které se profesionál zaměřuje.
  projectTypes      String[]

  // Dostupnost a spolupráce (§22.1)
  availability       Availability?
  collaborationForms CollaborationForm[]

  // Ceny (§22)
  pricingModel PricingModel?
  /// Doplňující poznámka k cenám (např. „od 1 500 Kč/h").
  pricingNote  String?

  // Stav a onboarding
  status            ProfileStatus @default(draft)
  /// Nezávislý přepínač „přijímám poptávky". Aktivovatelný jen s ≥1 profesí.
  acceptingRequests Boolean       @default(false)
  /// Poslední dokončený krok onboarding wizardu (0 = nezačato). Umožní návrat.
  onboardingStep    Int           @default(0)
  publishedAt       DateTime?
  /// Veřejná URL část profilu (`/profesional/[slug]`). Generuje se z titulku při
  /// první publikaci a dál se nemění (stabilní odkaz). Draft ho ještě nemá. (T008)
  slug              String?       @unique

  professions ProfileProfession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("professional_profiles")
}

/// Vazba profil↔profese (M:N) s příznakem hlavní profese. `isPrimary` má právě
/// jeden řádek profilu (vynuceno parciálním unikátním indexem v migraci +
/// service vrstvou). Profesi nelze smazat, dokud je použitá (`Restrict`) —
/// archivace profese profil neruší (edge case: profese archivovaná adminem).
model ProfileProfession {
  id           String              @id @default(cuid())
  profileId    String
  profile      ProfessionalProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  professionId String
  profession   Profession          @relation(fields: [professionId], references: [id], onDelete: Restrict)
  /// Hlavní profese profilu (právě jedna). Ostatní jsou vedlejší.
  isPrimary    Boolean             @default(false)
  createdAt    DateTime            @default(now())

  @@unique([profileId, professionId])
  @@index([professionId])
  @@map("profile_professions")
}

// ---------------------------------------------------------------------------
// Organizace (T009)
//
// Firemní profil s více členy a interními rolemi (owner/admin/editor/member).
// Jedna osoba může být členem víc firem (M:N přes `OrganizationMember`); žádný
// předpoklad „jedna firma na uživatele" (viz zadani/16 §11). Interní role firmy
// stojí NAD systémovými rolemi z T004 — vynucují se přes lib/permissions.ts nad
// členstvím, ne přes globální role. Invariant „min. 1 owner" se drží v service
// vrstvě (transakce + počet ownerů), ne DB constraintem (víc ownerů je validní).
// Recruiter/sales role a pobočky jsou post-MVP (mimo scope). Veřejná stránka: T010.
// ---------------------------------------------------------------------------

/// Životní cyklus firmy. `archived` firma zůstává, ale je skrytá/neaktivní.
enum OrgStatus {
  active
  archived
}

/// Interní role člena ve firmě. Hierarchie: owner > admin > editor > member.
/// owner: vše (vč. předání vlastnictví, archivace); admin: členové + profil;
/// editor: profil; member: čtení interních dat. Recruiter/sales až po MVP.
enum OrgRole {
  owner
  admin
  editor
  member
}

/// Stav pozvánky. `pending` → `accepted`/`declined`; `expired` je odvozený stav
/// (po 14 dnech), počítá se ze `expiresAt` — v DB může zůstat `pending`.
enum OrgInvitationStatus {
  pending
  accepted
  declined
  expired
}

/// Firemní profil. Drží prezentaci a business identitu; členy a role řeší
/// `OrganizationMember`. Zakladatel se při vzniku stává ownerem (service vrstva).
model Organization {
  id String @id @default(cuid())

  name            String
  /// Stabilní veřejný slug pro `/firma/[slug]` (T010). Vzniká z názvu při
  /// založení, dál se nemění, aby veřejný odkaz zůstal stabilní. Nullable kvůli
  /// firmám z T009 založeným před migrací; nová firma ho vždy dostane.
  slug            String?  @unique
  /// Odkaz na logo. Vlastní upload řeší T014; zde jen URL.
  logoUrl         String?
  description     String?
  /// IČO (business identity). Volitelné; duplicita je jen warning, ne blok.
  businessId      String?
  /// Sídlo firmy (město/obec).
  location        String?
  /// Regiony působnosti (volný číselník).
  serviceAreas    String[]
  /// Specializace firmy (volný číselník).
  specializations String[]

  // Veřejný kontakt (T010). Zobrazí se na veřejné stránce, jen když je vyplněný —
  // „firemní kontakt jen pokud jej owner explicitně zveřejní" (T010 § Permissions).
  // Kontakty jednotlivých členů se veřejně nikdy nezobrazují.
  /// Veřejný kontaktní e-mail firmy (opt-in — prázdné = nezveřejněno).
  publicEmail   String?
  /// Veřejný kontaktní telefon firmy (opt-in).
  publicPhone   String?
  /// Veřejný web firmy (opt-in).
  publicWebsite String?

  status OrgStatus @default(active)

  members           OrganizationMember[]
  invitations       OrganizationInvitation[]
  portfolioProjects PortfolioProject[] // T012 (owner = organizace)
  mediaAssets       MediaAsset[] // T014 (owner = organizace)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@map("organizations")
}

/// Členství uživatele ve firmě s interní rolí (M:N user↔org). Unikát na
/// dvojici (org, user) — jeden uživatel má ve firmě právě jednu roli.
model OrganizationMember {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  userId String
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   OrgRole @default(member)

  /// Opt-in člena k zobrazení ve veřejném týmu firmy (T010). Default `false` —
  /// členství je veřejně skryté, dokud ho člen sám nezveřejní. Skrytí členství
  /// = přepnout zpět na `false` (T010 alternative flow).
  publicVisible Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, userId])
  @@index([userId])
  @@map("organization_members")
}

/// Pozvánka nového člena e-mailem. V DB jen SHA-256 hash tokenu; plaintext jde
/// pouze e-mailem (stejný princip jako PasswordResetToken z T003). Existující
/// účet se po přihlášení připojí, neexistující projde registrací a pak se
/// připojí (řízeno návratovou URL po loginu). `invitedByUserId` je audit (bez
/// relace, jako `UserRole.grantedBy`). Expirace 14 dní.
model OrganizationInvitation {
  id    String       @id @default(cuid())
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  /// E-mail pozvaného (case-insensitive přes citext, jako User.email).
  email String  @db.Citext
  role  OrgRole @default(member)

  /// SHA-256 hash pozvánkového tokenu (plaintext jen v e-mailu).
  tokenHash String              @unique
  status    OrgInvitationStatus @default(pending)

  /// Kdo pozval (audit). Bez relace na User — jen ID.
  invitedByUserId String?
  expiresAt       DateTime
  /// Kdy pozvaný odpověděl (accepted/declined).
  respondedAt     DateTime?

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([email])
  @@map("organization_invitations")
}

// ---------------------------------------------------------------------------
// Verifikace (T011)
//
// Ověřovací záznam per (uživatel, typ). MVP implementuje `email` a `phone`;
// ostatní typy (identita, firma, kvalifikace, autorizace, pojištění) jsou zatím
// jen v enumu — na tuto infrastrukturu navážou vyšší úrovně (viz
// zadani/legacy-master-spec.md §37). Ověřovaný kontakt (`value`) je soukromý;
// veřejně čitelný je jen stav jako badge, který kontakt nikdy nezobrazuje.
// Absence záznamu = `unverified`. Vazba na cizí model User je FK ze svého modelu.
// ---------------------------------------------------------------------------

/// Co se ověřuje. MVP: `email`, `phone`. Ostatní typy jsou vyhrazené pro
/// finální produkt (identita/firma/autorizace/pojištění) a zatím se nepoužívají.
enum VerificationType {
  email
  phone
  identity
  business
  qualification
  authorization
  insurance
}

/// Stav ověření. `unverified` je reprezentován absencí záznamu; jakmile výzva
/// vznikne, řádek existuje ve stavu `pending`. `expired` u časově omezených výzev.
enum VerificationStatus {
  pending
  verified
  expired
}

/// Ověření jednoho kontaktu uživatele. Právě jeden řádek na (userId, type) —
/// nová žádost o ověření existující řádek přepíše (změna kontaktu = reset).
model Verification {
  id     String             @id @default(cuid())
  userId String
  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   VerificationType
  status VerificationStatus @default(pending)

  /// Ověřovaný kontakt (e-mail / telefon v E.164). Soukromý — badge ho nikdy
  /// nezobrazuje. Umožňuje detekovat změnu kontaktu (verifikace se pak resetuje)
  /// a drží telefon, který na User modelu (T002) není.
  value String

  /// SHA-256 hash tajemství výzvy: u `email` token z odkazu, u `phone` 6místný
  /// kód. Plaintext nikdy v DB. `null` po dokončení nebo než vznikne výzva.
  secretHash String?
  /// Expirace aktuální výzvy (telefon: 10 min, e-mail odkaz: delší).
  expiresAt  DateTime?
  /// Počet neúspěšných pokusů o zadání kódu (telefon). Limit dle konstanty.
  attempts   Int       @default(0)

  /// Kdy byla poslední výzva vydána a kdy (pokud) bylo ověření dokončeno.
  issuedAt   DateTime  @default(now())
  verifiedAt DateTime?

  /// Poznámky z ručního review (identita/firma). MVP nevyužito — připraveno pro
  /// pozdější admin verifikační frontu (out of scope T011).
  reviewNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@map("verifications")
}

// ---------------------------------------------------------------------------
// Portfolio projekt (T012)
//
// Portfolio dílo s polymorfním vlastníkem (uživatel NEBO organizace) a
// publikačním cyklem draft → published → draft. Vlastnictví je vyjádřeno dvojicí
// nullable sloupců `ownerUserId` / `ownerOrgId`; DB CHECK v migraci vynucuje, že
// je vyplněný právě jeden. Oba sloupce mají FK (User z T002, Organization z T009).
//
// Publikace pořizuje SNAPSHOT obsahu (`publishedSnapshot`): veřejná verze čte ze
// snapshotu, takže úpravy draftu se venku neprojeví do další publikace
// (legacy-master-spec §24–25). Uvedení spoluautorů je NAOPAK živé — čte se z
// potvrzených řádků `PortfolioCoauthor`, aby odvolání souhlasu jméno okamžitě
// skrylo (zadani/16-ai-team-execution-rules.md §7). Mazání je měkké (`deletedAt`).
// Blokový editor (T013), média (T014) a veřejný render (T016) jsou mimo T012.
// ---------------------------------------------------------------------------

/// Stav portfolio projektu. `draft` (jen editoři a pozvaní spoluautoři) →
/// `published` (veřejná verze ze snapshotu) → `archived` (staženo, neveřejné).
enum PortfolioStatus {
  draft
  published
  archived
}

/// Viditelnost publikované verze. `public` je dohledatelná a listovaná;
/// `unlisted` je dostupná jen přes přímý odkaz (nelistuje se).
enum PortfolioVisibility {
  public
  unlisted
}

/// Typ portfolio díla (legacy-master-spec §24). Volitelný — doplní se v editaci.
enum PortfolioProjectType {
  project // realizovaný projekt
  realization // realizace
  concept // koncept / studie
  technical_case_study // technická případová studie
  craft_realization // řemeslná realizace
  before_after // před / po
  competition // soutěžní návrh
  research // výzkumný projekt
}

/// Stav uvedení spoluautora. `invited` → `confirmed` (zobrazí se) / `declined`.
/// Bez `confirmed` se jméno na veřejné verzi nikdy neukáže.
enum PortfolioCoauthorStatus {
  invited
  confirmed
  declined
}

/// Portfolio dílo. Vlastníkem je uživatel (`ownerUserId`) nebo organizace
/// (`ownerOrgId`) — právě jeden (CHECK v migraci). Metadata jsou volná a vznikají
/// postupně; povinný je jen titul (validace v appce a při publikaci).
model PortfolioProject {
  id String @id @default(cuid())

  /// Vlastník = uživatel (profesionál). FK na User. Právě jeden z owner sloupců.
  ownerUserId String?
  ownerUser   User?         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  /// Vlastník = organizace (T009). Integrita „právě jeden vlastník" je zajištěná
  /// CHECK v migraci.
  ownerOrgId  String?
  ownerOrg    Organization? @relation(fields: [ownerOrgId], references: [id], onDelete: Cascade)

  // Metadata (T012 § Inputs)
  /// Titul díla. Povinný (validace v appce; DB drží NOT NULL až přes službu).
  title       String
  /// Typ díla (viz enum). Volitelný.
  projectType PortfolioProjectType?
  /// Lokalita — jen město/region (bez přesné adresy, legacy-master-spec §24).
  location    String?
  /// Rok realizace/dokončení. Volitelný; rozsah hlídá validace.
  year        Int?
  /// Krátký popis díla (perex). Delší obsah řeší blokový editor (T013).
  description String?

  visibility PortfolioVisibility @default(public)
  status     PortfolioStatus     @default(draft)

  /// Stabilní veřejný slug pro `/projekt/[slug]` (T016). Vzniká z titulku při
  /// první publikaci a dál se nemění, aby veřejný odkaz zůstal stabilní. Draft
  /// ho ještě nemá (`null`) — jeho náhled běží přes id (`?preview=1`).
  slug String? @unique

  /// Zmražený obsah publikované verze (metadata + bloky z T013). Veřejná verze
  /// čte odsud, takže úpravy draftu ji nemění do další publikace. `null` = nikdy
  /// nepublikováno. Struktura viz features/portfolio/public-view.ts.
  publishedSnapshot Json?
  /// První publikace (nemění se dalšími publikacemi ani unpublishem) — stabilní
  /// datum vzniku veřejné verze.
  publishedAt       DateTime?
  /// Měkké smazání. Neprázdné = projekt je zrušený a nikde se nenabízí.
  deletedAt         DateTime?

  /// Monotónní verze obsahových bloků draftu (T013). Editor ji načte při otevření
  /// a posílá zpět při autosave; když se mezitím změní (souběžná editace druhým
  /// editorem), server uloží stejně (last-write-wins), ale vrátí varování.
  blocksVersion Int @default(0)

  coauthors PortfolioCoauthor[]
  /// Obsahové bloky DRAFT verze (T013). Publikace (T012) je zmrazí do
  /// `publishedSnapshot`; veřejná verze čte ze snapshotu, ne odsud.
  blocks    PortfolioBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerUserId])
  @@index([ownerOrgId])
  @@index([status])
  @@map("portfolio_projects")
}

/// Obsahový blok portfolia (T013). Patří DRAFT verzi díla; pořadí drží `order`
/// (0…n). `type` je jeden z MVP typů (heading, text, quote, list, table,
/// technical_data, cta, image, gallery, before_after); `content` je volný JSON
/// dle typu (Zod schéma ve `features/portfolio/blocks.ts`). Ukládání je „nahraď
/// vše" v transakci — editor posílá celý dokument, server řádky přepíše. Publikace
/// bloky zvaliduje (strict) a zmrazí do snapshotu projektu.
model PortfolioBlock {
  id        String           @id @default(cuid())
  projectId String
  project   PortfolioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Typ bloku (řetězec, ať přidání typu nevyžaduje DB migraci enumu).
  type    String
  /// Pořadí v rámci díla (0-based). Editor přeřazuje změnou tohoto sloupce.
  order   Int
  /// Obsah bloku dle typu (volný JSON; draft smí být i neúplný, publikace ho pak
  /// nezvaliduje a vynechá — žádná tichá ztráta draftu).
  content Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, order])
  @@map("portfolio_blocks")
}

/// Spoluautor díla. Jméno se veřejně zobrazí až po `confirmed`; odvolání souhlasu
/// (`declined`) ho hned skryje. Právě jeden řádek na (projekt, uživatel).
model PortfolioCoauthor {
  id        String           @id @default(cuid())
  projectId String
  project   PortfolioProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  status PortfolioCoauthorStatus @default(invited)

  invitedAt   DateTime  @default(now())
  /// Kdy spoluautor potvrdil/odmítl (poslední změna stavu). `null` = dosud čeká.
  respondedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
  @@index([userId])
  @@map("portfolio_coauthors")
}

// ---------------------------------------------------------------------------
// Média — upload + knihovna (T014)
//
// Sdílená služba pro portfolio (T012/T013), profily (T007) a přílohy (T023).
// Vlastník je polymorfní (uživatel NEBO organizace) — stejný vzor jako portfolio:
// dvojice nullable sloupců `ownerUserId` / `ownerOrgId` + DB CHECK „právě jeden".
// Oba mají FK (User z T002, Organization z T009 — obě tabulky už existují).
//
// KLÍČOVÝ INVARIANT: originál se nikdy nepřepisuje (zadani/16 §7). `originalKey`
// je uložený nahraný soubor v původní podobě; deriváty (`thumbnailKey`,
// `webKey`) jsou vždy NOVÉ soubory a nesmí obsahovat GPS EXIF (privacy). Úpravy
// (T015) taktéž vytvoří nový derivát, originál zůstane obnovitelný. Fyzická data
// drží storage adaptér (filesystem v dev, S3 v prod) — v DB jen klíče.
//
// Mazání je měkké (`status = deleted`), aby originál zůstal obnovitelný; asset
// použitý v PUBLIKOVANÉM obsahu smazat nelze (blok s odkazy — usage seam ve
// features/media/usage.ts). Viditelnost: asset vidí a používá jen vlastník;
// veřejně se servírují jen deriváty assetů použitých v publikovaném obsahu.
// ---------------------------------------------------------------------------

/// Stav média. `active` (dostupné) → `deleted` (měkce smazané; originál a klíče
/// zůstávají kvůli obnovitelnosti a doběhu odkazů). Terminální je `deleted`.
enum MediaStatus {
  active
  deleted
}

/// Nahraný obrázek s originálem a deriváty. Vlastník je uživatel (`ownerUserId`)
/// nebo organizace (`ownerOrgId`) — právě jeden (CHECK v migraci). Originál se
/// nikdy nepřepisuje; deriváty jsou samostatné soubory bez GPS EXIF.
model MediaAsset {
  id String @id @default(cuid())

  /// Vlastník = uživatel. FK na User. Právě jeden z owner sloupců.
  ownerUserId String?
  ownerUser   User?         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  /// Vlastník = organizace (T009). Integrita „právě jeden vlastník" je CHECK v migraci.
  ownerOrgId  String?
  ownerOrg    Organization? @relation(fields: [ownerOrgId], references: [id], onDelete: Cascade)

  /// MIME typ originálu (z whitelistu: image/jpeg | image/png | image/webp).
  mimeType     String
  /// Storage klíč nepřepisovaného originálu.
  originalKey  String
  /// Storage klíč náhledu (thumbnail). `null`, dokud se derivát nevygeneruje.
  thumbnailKey String?
  /// Storage klíč web-optimalizované varianty.
  webKey       String?

  /// Rozměry originálu v px (z metadat).
  width    Int
  height   Int
  /// Velikost originálu v bajtech.
  byteSize Int

  /// SHA-256 hash bajtů originálu — dedup v rámci vlastníka (volitelné; kolize
  /// jen varuje, neblokuje). Umožní „už nahráno" bez druhé kopie.
  contentHash String

  /// Alternativní text (přístupnost). Volitelný, doplnitelný v knihovně.
  altText String?

  /// Úpravy obrázku (T015): normalizované parametry aktivní verze (rotace, crop,
  /// jas/kontrast/saturace). `null` = originál beze změn. Deriváty se vždy renderují
  /// z ORIGINÁLU s těmito parametry — opakovaná úprava nedegraduje kvalitu.
  editParams         Json?
  /// Storage klíč náhledu upravené verze. `null` = zobrazuje se `thumbnailKey` (originál).
  editedThumbnailKey String?
  /// Storage klíč web varianty upravené verze. `null` = zobrazuje se `webKey` (originál).
  editedWebKey       String?
  /// Rozměry upravené verze (po rotaci/cropu). `null` = platí `width`/`height` originálu.
  editedWidth        Int?
  editedHeight       Int?

  status MediaStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerUserId])
  @@index([ownerOrgId])
  @@index([contentHash])
  @@map("media_assets")
}

// ---------------------------------------------------------------------------
// Guide — schema engine (T017)
//
// Datově řízený guide: otázky (kroky) jsou definované DATY, ne kódem. Scénář je
// verzovaný — běžící session dokončí svou verzi i po vydání nové (session drží FK
// na konkrétní `GuideScenario` řádek = konkrétní verzi). Podmíněné větvení popisuje
// deklarativní JSON DSL v `GuideStep.condition`, vyhodnocované na serveru
// (features/guide/conditions.ts). Rozpory hlídají pravidla v `GuideScenario.conflicts`.
//
// Session funguje i pro NEPŘIHLÁŠENÉHO: identifikuje ho neuhádnutelný `token`
// (cookie). Po registraci/loginu se anonymní session připojí k účtu naplněním
// `userId` (legacy-master-spec §54) — token zůstává kvůli doběhu.
//
// KLÍČOVÝ INVARIANT: „nevím" i „přeskočit" jsou VALIDNÍ odpovědi a nikdy neblokují
// postup (zadani/16 §4). Odpověď na krok, který se po změně dřívější odpovědi
// dostal na neplatnou větev, se NEMAŽE — jen se přestane počítat (engine ji hlásí
// jako „stale"). Detaily enginu: features/guide/engine.ts.
//
// Mimo T017: UI (T018), obsah reálných scénářů (T019), shrnutí/warningy (T020),
// admin editace scénářů (T035).
// ---------------------------------------------------------------------------

/// Typ otázky (kroku). Zrcadlí `GUIDE_STEP_TYPES` ve features/guide/types.ts.
/// Každý typ má vlastní tvar hodnoty odpovědi i validaci.
enum GuideStepType {
  single_choice
  multi_choice
  text
  number
  range
  location
  file_ref
}

/// Životní cyklus session. `active` → `completed` (dokončeno) | `abandoned`
/// (opuštěno). Terminální jsou `completed` i `abandoned`.
enum GuideSessionState {
  active
  completed
  abandoned
}

/// Verzovaný scénář guide. Jedinečný je pár (slug, verze); pro daný slug běží
/// nová session na nejvyšší `active` verzi, rozběhnutá session dokončí svou.
/// `conflicts` drží deklarativní pravidla rozporů (pole `{ key, message, when }`).
model GuideScenario {
  id      String  @id @default(cuid())
  /// Stabilní identifikátor scénáře napříč verzemi (např. `co-chcete-vyresit`).
  slug    String
  /// Verze scénáře (monotónně roste). Nová verze = nový řádek se stejným slugem.
  version Int     @default(1)
  name    String
  /// Smí se z tohoto scénáře zakládat nová session? Deaktivace neruší běžící session.
  active  Boolean @default(true)

  /// Deklarativní pravidla rozporů (JSON: `{ key, message, when: <DSL> }[]`).
  /// Vyhodnocuje engine nad odpověďmi; UI (T020) je zpracuje jako varování.
  conflicts Json @default("[]")

  /// Výstupy koncových větví (T019). JSON: `GuideOutcome[]` — mapování odpovědí na
  /// doporučené profese (slugy T005), další krok, podklady a `safetyWarning` (§15).
  /// Každá průchozí větev musí sednout aspoň na jeden výstup (žádná slepá ulička).
  outcomes Json @default("[]")

  steps    GuideStep[]
  sessions GuideSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, version])
  @@index([slug])
  @@map("guide_scenarios")
}

/// Jeden krok (otázka) scénáře. Data, ne kód. Pořadí drží `position`; zobrazení
/// řídí volitelná `condition` (JSON DSL nad dřívějšími odpověďmi).
model GuideStep {
  id         String        @id @default(cuid())
  scenarioId String
  scenario   GuideScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  /// Stabilní klíč kroku v rámci scénáře; klíčem se na krok odkazují podmínky
  /// i uložené odpovědi (`GuideSession.answers`).
  key      String
  type     GuideStepType
  /// Pořadí v rámci scénáře (0-based). Určuje i „dřívější/pozdější" pro podmínky.
  position Int

  /// Text otázky.
  prompt String
  /// Vysvětlivka nejasného pojmu (volitelná).
  help   String?

  /// Možnosti pro single/multi-choice (JSON: `{ value, label, help? }[]`).
  options   Json    @default("[]")
  /// Konfigurace typu (JSON: min/max u number/range, maxLength u textu, …).
  config    Json    @default("{}")
  /// Podmínka zobrazení (JSON DSL). `null` = krok se zobrazí vždy.
  condition Json?
  /// Je odpověď (hodnotou) povinná pro „úplný brief"? „nevím"/„přeskočit" je vždy
  /// přípustné a nezablokuje postup — povinnost jen značí chybějící podklad.
  required  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([scenarioId, key])
  @@index([scenarioId])
  @@map("guide_steps")
}

/// Průchod scénářem. Vlastník je přihlášený uživatel (`userId`) NEBO anonym
/// identifikovaný `token`em z cookie; anonymní session se po registraci připojí
/// naplněním `userId`. `answers` je mapa `klíč kroku → odpověď` (JSON).
model GuideSession {
  id         String        @id @default(cuid())
  scenarioId String
  scenario   GuideScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  /// Vlastník po přihlášení. `null` u anonymní session (identifikuje ji `token`).
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Neuhádnutelný token session (cookie). Vlastnictví anonymní session = držení
  /// tokenu; zůstává i po připojení k účtu.
  token String @unique

  /// Uložené odpovědi: `{ [stepKey]: { status, value? } }` (JSON).
  answers Json @default("{}")

  state GuideSessionState @default(active)

  startedAt   DateTime  @default(now())
  /// Kdy session přešla do terminálního stavu (`completed`/`abandoned`).
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Briefy vygenerované z této session (T021). Vazba je SNAPSHOTOVÁ: brief drží
  /// vlastní kopii obsahu a smazání session ho neruší (FK `onDelete: SetNull`).
  briefs Brief[]

  @@index([userId])
  @@index([scenarioId])
  @@map("guide_sessions")
}

// ---------------------------------------------------------------------------
// Attachment systém (T023)
//
// Generický systém příloh (dokumenty, PDF, obrázky) použitelný napříč doménami:
// brief (T022), poptávka (T024), reakce (T027), zprávy (T031). Konkrétní doménu
// task nezná — kontext je POLYMORFNÍ dvojicí `contextType` (např. `brief`,
// `request`) + `contextId`. Doména si u `lib/attachments.ts` registruje resolver,
// který řekne, kdo je účastníkem daného kontextu; příloha sama žádnou doménovou
// logiku nedrží (konzumující tasky nepíší vlastní přístupovou logiku).
//
// KLÍČOVÝ INVARIANT: nová příloha je VŽDY `private` (zadani/16 §6 — least
// privilege). Zpřístupnění (`shared_in_context`/`public`) je vědomá akce; u
// přílohy se `sensitive` flagem vyžaduje navíc explicitní potvrzení
// (zadani/12 §8). Přístup ke stažení jde vždy přes autorizovanou routu
// (`GET /api/attachments/[id]`) — soukromý soubor není dosažitelný žádnou
// nepodepsanou URL (leží mimo `public/`, řídí ho `canAccess`).
//
// Fyzická data drží storage adaptér (filesystem v dev, S3 v prod) — v DB jen
// `storageKey`. Záznam vzniká AŽ po potvrzeném uploadu (žádné osiřelé řádky).
// Mazání je měkké (`status = deleted`); konzumující kontext zobrazí placeholder
// „příloha byla odstraněna", ne rozbitý odkaz. Antivirus/scanning a verzování
// souborů jsou mimo scope.
// ---------------------------------------------------------------------------

/// Viditelnost přílohy. `private` (jen vlastník) je výchozí; `shared_in_context`
/// (účastníci daného kontextu — vyhodnotí resolver domény); `public` (kdokoli).
enum AttachmentVisibility {
  private
  shared_in_context
  public
}

/// Stav přílohy. `active` → `deleted` (měkce; soubor ve storage zůstává, aby šel
/// doběhnout odkaz na placeholder a případně obnovit). Terminální je `deleted`.
enum AttachmentStatus {
  active
  deleted
}

/// Nahraná příloha s explicitní viditelností a sensitivity flagem. Vlastníkem je
/// vždy uživatel (`ownerUserId`, FK na User z T002). Kontext je polymorfní
/// (`contextType` + `contextId`) — na cizí doménové modely se neváže FK, vazbu
/// vyhodnocuje resolver registrovaný doménou. Tentýž soubor přiložený do dvou
/// kontextů = dva řádky (viditelnost se řídí nezávisle).
model Attachment {
  id String @id @default(cuid())

  /// Vlastník přílohy (nahravatel). Vlastník má přístup vždy.
  ownerUserId String
  ownerUser   User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  /// Polymorfní kontext: typ domény (`brief`, `request`, `response`, `message`, …)
  /// a ID entity v ní. Bez FK na cizí model (vazbu řeší resolver domény).
  contextType String
  contextId   String

  /// Storage klíč nahraného souboru (fyzická data drží storage adaptér).
  storageKey String
  /// MIME typ z whitelistu (detekováno z obsahu, ne jen z přípony).
  mimeType   String
  /// Původní, sanitizovaný název souboru (pro zobrazení a stažení).
  fileName   String
  /// Velikost souboru v bajtech.
  byteSize   Int

  /// Explicitní viditelnost. Nová příloha je vždy `private` (zadani/16 §6).
  visibility AttachmentVisibility @default(private)
  /// Sensitivity flag: obsahuje citlivá/osobní data → zveřejnění vyžaduje
  /// explicitní potvrzení (zadani/12 §8).
  sensitive  Boolean              @default(false)

  /// Volná metadata (JSON) — konzumující doména si sem uloží, co potřebuje.
  metadata Json?

  status AttachmentStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerUserId])
  @@index([contextType, contextId])
  @@map("attachments")
}

// ---------------------------------------------------------------------------
// Brief — generování z guide (T021)
//
// Strukturovaný projektový brief vygenerovaný z DOKONČENÉ guide session (T017–T020)
// se všemi povinnými částmi dle legacy-master-spec §18. Brief je most mezi guide a
// marketplace — teprve on je hmatatelný výstup průvodce.
//
// KLÍČOVÝ INVARIANT „SNAPSHOT, NE ŽIVÁ VAZBA" (zadani/09 — Brief): brief drží
// VLASTNÍ kopii vygenerovaného obsahu (`content` JSON) i názvu. Smazání zdrojové
// session ho neruší — FK `guideSessionId` je `onDelete: SetNull`. Opětovné
// generování z téže session aktualizuje EXISTUJÍCÍ draft (žádné duplicity), ale
// jen dokud je `draft`; sdílený brief se nepřepíše (revizi řeší T022).
//
// POCTIVOST (zadani/16 §4): „nevím"/„přeskočit" se do briefu propíšou jako
// neznámé/chybějící, nikdy jako dopočítaná hodnota. Přesná adresa z guide zůstává
// jen v soukromém poli `content` a nikdy se nedostane do názvu ani shrnutí
// (zadani/09 — Brief). Nová položka je vždy `draft` + `private` (least privilege).
//
// Tento task: model + generátor + přechod `draft → ready`. Manuální editace,
// sdílení a export řeší T022; přílohy T023; poptávka T024. Stavy `shared`/`revised`
// jsou v enumu pro dopřednou kompatibilitu, ale přechody na ně jsou mimo scope.
// ---------------------------------------------------------------------------

/// Životní cyklus briefu (zadani/08 §2). `draft → ready → shared`,
/// `shared → revised → shared`, `draft → archived`. T021 implementuje jen
/// `draft` (vznik) a přechod `draft → ready`; zbytek řeší T022.
enum BriefStatus {
  draft
  ready
  shared
  revised
  archived
}

/// Viditelnost briefu. Nová položka je vždy `private` (jen vlastník). Sdílení
/// (`shared_link`/`public`) je vědomá akce v T022.
enum BriefVisibility {
  private
  shared_link
  public
}

/// Strukturovaný projektový brief (§18). Vlastníkem je VŽDY přihlášený uživatel
/// (`ownerUserId`) — anonym je před vytvořením vyzván k registraci a session se
/// k účtu připojí (T017). `content` je snapshot všech povinných sekcí (tvar
/// validuje `features/brief/content.ts`); dotazovatelné atributy (název, stav,
/// viditelnost) jsou vlastní sloupce.
model Brief {
  id String @id @default(cuid())

  /// Vlastník briefu. Čte/píše jen on (`lib/permissions.ts` → `brief.*`).
  ownerUserId String
  ownerUser   User   @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)

  /// Zdrojová guide session. Nullable + `SetNull`: brief je snapshot a smazání
  /// session ho nesmí zrušit (zadani/09 — Brief).
  guideSessionId String?
  guideSession   GuideSession? @relation(fields: [guideSessionId], references: [id], onDelete: SetNull)

  /// Snapshot slugu scénáře (kvůli přehledům i po smazání session).
  scenarioSlug String

  /// Automaticky navržený název (§18), editovatelný v T022. Nikdy neobsahuje
  /// přesnou adresu (zadani/09 — Brief).
  title String

  /// Snapshot všech povinných sekcí §18 (JSON `BriefContent`). Zdroj pravdy pro
  /// zobrazení i po smazání session.
  content Json

  status     BriefStatus     @default(draft)
  visibility BriefVisibility @default(private)

  /// Kdy byl obsah naposledy vygenerován z odpovědí (regenerace ho aktualizuje).
  generatedAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerUserId])
  @@index([guideSessionId])
  @@map("briefs")
}

// ---------------------------------------------------------------------------
// Messaging (T030)
//
// Konverzace 1:1 mezi přihlášenými uživateli, textové zprávy, stav přečtení,
// inbox. Kontext vzniku je polymorfní (`contextType` + `contextId`, bez FK na
// cizí model — stejně jako u příloh) — konverzace vzniká z poptávky/reakce/
// profilu, nebo napřímo. Přílohy, block/report, ochrana kontaktů a skupinové
// konverzace jsou mimo scope (T031 / finální produkt).
// ---------------------------------------------------------------------------

/// Moderační stav zprávy. `visible` (default) → `hidden` (skryje T036 přes
/// report); obsah se nemaže, jen se přestane zobrazovat účastníkům.
enum MessageModerationState {
  visible
  hidden
}

/// Konverzace více účastníků (v MVP vždy 1:1). Znovupoužití stejné dvojice ve
/// stejném kontextu hlídá unikátní `dedupeKey` (deterministický z kontextu a
/// seřazených ID účastníků) → nikdy nevzniknou dvě konverzace téže dvojice ve
/// stejném kontextu. `lastMessageAt` řadí inbox bez agregace přes zprávy.
model Conversation {
  id String @id @default(cuid())

  /// Polymorfní kontext vzniku (`request`, `response`, `profile`, …) nebo NULL
  /// pro přímou konverzaci. Bez FK na cizí model (vazbu zná zdrojová doména).
  contextType String?
  contextId   String?

  /// Deterministický klíč pro znovupoužití:
  /// `<contextType|direct>:<contextId>:<seřazená userId účastníků>`. Unikátní →
  /// findOrCreate je idempotentní i při souběhu (race → jeden řádek vyhraje).
  dedupeKey String @unique

  /// Čas poslední zprávy (řazení inboxu). NULL = konverzace zatím bez zpráv
  /// (může vzniknout prázdná při zahájení z kontextu).
  lastMessageAt DateTime?

  participants ConversationParticipant[]
  messages     Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contextType, contextId])
  @@map("conversations")
}

/// Účast uživatele v konverzaci. Nese per-účastník stav: `lastReadAt` (výpočet
/// nepřečtených) a `archivedAt` (archivace je individuální — druhý účastník
/// konverzaci dál vidí aktivní).
model ConversationParticipant {
  id String @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Do kdy má účastník přečteno. Zpráva novější než tento čas (a ne od něj) je
  /// pro účastníka nepřečtená. NULL = ještě si konverzaci neotevřel.
  lastReadAt DateTime?
  /// Archivováno tímto účastníkem (per-účastník). NULL = aktivní v inboxu.
  archivedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

/// Textová zpráva v konverzaci. Obsah se renderuje VŽDY jako text (XSS: nikdy
/// HTML). `clientToken` je idempotenční klíč odeslání z klienta (double-click
/// nevytvoří duplikát). `replyToId` je volitelná odpověď na konkrétní zprávu.
model Message {
  id String @id @default(cuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  /// Odesílatel. Při zrušení účtu (soft delete → status=deleted) zpráva zůstává
  /// a UI vykreslí placeholder identitu „zrušený účet" (zadani/09 — Messaging).
  senderUserId String
  sender       User   @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  content String

  /// Odpověď na konkrétní zprávu (reply reference). Self-relace, volitelná;
  /// smazání cílové zprávy odkaz vynuluje (SetNull), vlákno se nerozbije.
  replyToId String?
  replyTo   Message?  @relation("MessageReply", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("MessageReply")

  /// Idempotenční klíč odeslání z klienta (UUID). Unikátní v rámci konverzace →
  /// opakované odeslání téhož tokenu vrátí existující zprávu místo duplikátu.
  clientToken String

  moderationState MessageModerationState @default(visible)

  createdAt DateTime @default(now())

  @@unique([conversationId, clientToken])
  @@index([conversationId, createdAt])
  @@map("messages")
}

// --- Notifikace (T032) ------------------------------------------------------

/// Priorita notifikace (zadani/11 — Priority). Řídí zvýraznění v centru a
/// (v navazujících taskech) výběr kanálů; v MVP se materializuje jen in-app.
enum NotificationPriority {
  low
  normal
  high
  urgent
}

/// Stav notifikace pro příjemce. `unread → read`; podporuje hromadné označení.
enum NotificationState {
  unread
  read
}

/// In-app notifikace pro příjemce (T032). Vzniká VÝHRADNĚ přes jednotné emit API
/// (`lib/notifications.ts`), které volají domény (messaging, marketplace, …) —
/// model nezná konkrétní doménu: kontext je polymorfní (`contextType`+`contextId`,
/// bez FK) a cíl kliknutí je uložená relativní `linkPath`.
///
/// Deduplikace: dokud je notifikace NEPŘEČTENÁ, opakovaný emit se stejným
/// `dedupeKey` jen zvýší `count` a `lastEventAt` místo nového řádku (5 zpráv v
/// jedné konverzaci = 1 nepřečtená notifikace s počtem). Po přečtení zakládá emit
/// novou notifikaci. `lastEventAt` řadí centrum (bump ji vrátí nahoru); mazání
/// není — přečtené zůstávají v historii.
model Notification {
  id String @id @default(cuid())

  recipientUserId String
  recipient       User   @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  /// Typ události z katalogu (`lib/notifications` — otevřený enum validovaný
  /// v kódu, ne v DB, aby šel rozšířit bez migrace). Např. `new_message`.
  eventType String

  priority NotificationPriority @default(normal)
  state    NotificationState    @default(unread)

  /// Krátký titulek bez citlivého obsahu (např. „Nová zpráva"). Nikdy neobsahuje
  /// obsah, na který příjemce nemusí mít právo (zadani/11 — Pravidla, T032 § Perm).
  title String
  /// Důvod, proč notifikaci příjemce dostal (zadani/11 — „uživatel musí znát důvod").
  reason String
  /// Cíl kliknutí — relativní cesta do kontextu (povinná). Vede na smysluplnou
  /// stránku i když kontext mezitím zmizí (nedostupnost řeší cílová stránka).
  linkPath String

  /// Polymorfní odkaz na zdrojový kontext (bez FK — vazbu zná zdrojová doména).
  contextType String?
  contextId   String?

  /// Klíč deduplikace (deterministický ze zdroje, např. `new_message:<convId>`).
  dedupeKey String
  /// Kolik událostí se do (nepřečtené) notifikace sloučilo. 1 = jediná událost.
  count Int @default(1)

  /// Kdy byla přečtena (`state = read`). NULL = nepřečtená.
  readAt DateTime?
  /// Čas poslední události v notifikaci (create i dedup-bump) — řadí centrum.
  /// Oddělené od `updatedAt`, aby označení přečteno nepřerovnalo seznam.
  lastEventAt DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipientUserId, state])
  @@index([recipientUserId, lastEventAt])
  // Dedup navíc vynucuje ČÁSTEČNÝ unikátní index (recipientUserId, dedupeKey)
  // WHERE state = 'unread' — Prisma ho neumí vyjádřit, drží ho ruční migrace
  // `notification_dedup_unique_unread` (kolizi P2002 řeší createOrBumpNotification).
  @@index([recipientUserId, dedupeKey])
  @@map("notifications")
}
